# Job Application Co-Pilot - environment template.
#
# How to use:
#   1. Copy this file to ".env":
#        macOS / Linux:        cp .env.example .env
#        Windows PowerShell:   Copy-Item .env.example .env
#   2. Fill in the real secret values below.
#   3. Don't commit the real ".env" (it's git-ignored).

# --- Application metadata ----------------------------------------------------
APP_NAME="Job Application Co-Pilot"
ENVIRONMENT=development               # development | production
DEBUG=true                           # Verbose errors & auto-reload friendliness

# --- Security / JSON Web Tokens ----------------------------------------------
# Generate a strong secret, e.g.:
#   python -c "import secrets; print(secrets.token_urlsafe(64))"
JWT_SECRET_KEY=ewdXZBAQNBuyhF8ySbf4thRhjXjSGeXQpDtWDlyTiWc
JWT_ALGORITHM=HS256                  # Signing algorithm for access tokens
ACCESS_TOKEN_EXPIRE_MINUTES=60       # How long an issued login token stays valid

# --- Database ----------------------------------------------------------------
# Local development needs NO database setup: leave DATABASE_URL unset and the app
# automatically uses a local SQLite file (backend/job_copilot.db).
#
# PRODUCTION ONLY: set DATABASE_URL to your managed PostgreSQL URL. On Render this
# is wired up for you automatically; Render hands out the legacy "postgres://"
# scheme, which the app rewrites to "postgresql://" on its own.
# Example: DATABASE_URL=postgresql://user:password@host:5432/dbname

# --- CORS --------------------------------------------------------------------
# Comma-separated list of frontend origins allowed to call this API.
# (VS Code "Live Server" defaults to port 5500.)
BACKEND_CORS_ORIGINS=http://localhost:5500,http://127.0.0.1:5500

# --- LLM provider selection --------------------------------------------------
# Which provider the LangGraph agents talk to: "groq" or "openai".
LLM_PROVIDER=groq

# Groq (fast, free-tier friendly) - https://console.groq.com/keys
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile

# OpenAI - https://platform.openai.com/api-keys
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# --- Agent tuning ------------------------------------------------------------
LLM_TEMPERATURE=0.3                  # Lower = more deterministic, focused output
LLM_REQUEST_TIMEOUT_SECONDS=60       # Hard ceiling per LLM call before failing
