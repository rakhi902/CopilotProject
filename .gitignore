# Job Application Co-Pilot - git ignore rules

# Python bytecode & caches
__pycache__/
*.py[cod]
*$py.class
*.egg-info/
.pytest_cache/
.mypy_cache/

# --- Virtual environment (lives at backend/.venv) ---
.venv/
venv/
env/

# --- Secrets & local environment files ---
.env
backend/.env

# --- SQLite database files ---
*.db
*.sqlite3
*.sqlite

# --- OS & editor cruft ---
.DS_Store
Thumbs.db
.vscode/
.idea/
